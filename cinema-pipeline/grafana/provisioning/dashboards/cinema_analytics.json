{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Cinema analytics: DAU, conversion, retention cohort heatmap, top movies",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "DAU – Daily Active Users",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cinema-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT toDateTime(metric_date) AS time, toFloat64(dau) AS value FROM cinema.agg_dau ORDER BY metric_date",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "displayName": "DAU"
        }
      },
      "options": { "tooltip": { "mode": "single" } }
    },
    {
      "id": 2,
      "title": "View Conversion Rate (VIEW_FINISHED / VIEW_STARTED)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cinema-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT toDateTime(metric_date) AS time, toFloat64(conversion_rate) AS value FROM cinema.agg_conversion ORDER BY metric_date",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "displayName": "Conversion"
        }
      }
    },
    {
      "id": 3,
      "title": "Top 10 Movies",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cinema-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT movie_id, toFloat64(sum(view_count)) AS total_views FROM cinema.agg_top_movies GROUP BY movie_id ORDER BY total_views DESC LIMIT 10",
          "format": "table"
        }
      ],
      "options": {
        "xField": "movie_id",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": { "displayName": "Views" }
      }
    },
    {
      "id": 4,
      "title": "Average Watch Time (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cinema-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT toDateTime(metric_date) AS time, toFloat64(avg_seconds) AS value FROM cinema.agg_avg_watch_time ORDER BY metric_date",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "displayName": "Avg watch time"
        }
      }
    },
    {
      "id": 5,
      "title": "Retention Cohort Heatmap (D0–D7)",
      "description": "Rows = cohort date (first VIEW_STARTED). Columns = Day 0..7. Cell = % users retained.",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cinema-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  toString(cohort_date) AS \"Cohort\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 0) AS \"Day 0\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 1) AS \"Day 1\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 2) AS \"Day 2\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 3) AS \"Day 3\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 4) AS \"Day 4\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 5) AS \"Day 5\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 6) AS \"Day 6\",\n  maxIf(toString(round(retention_rate * 100, 1)) || '%', day_number = 7) AS \"Day 7\"\nFROM cinema.agg_retention\nGROUP BY cohort_date\nORDER BY cohort_date DESC\nLIMIT 30",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Day 0" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "cellHeight": "sm",
        "showHeader": true
      }
    },
    {
      "id": 6,
      "title": "Device Type Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cinema-clickhouse" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT toString(device_type) AS device_type, toFloat64(sum(event_count)) AS cnt FROM cinema.agg_device_distribution GROUP BY device_type ORDER BY cnt DESC",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              { "fieldName": "device_type", "handlerKey": "field.name" },
              { "fieldName": "cnt", "handlerKey": "field.value" }
            ]
          }
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"]
      }
    },
    {
      "id": 7,
      "title": "Retention D1 vs D7 over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cinema-clickhouse" },
      "targets": [
        {
          "refId": "D1",
          "rawSql": "SELECT toDateTime(cohort_date) AS time, toFloat64(retention_rate) AS value FROM cinema.agg_retention WHERE day_number = 1 ORDER BY cohort_date",
          "format": "table"
        },
        {
          "refId": "D7",
          "rawSql": "SELECT toDateTime(cohort_date) AS time, toFloat64(retention_rate) AS value FROM cinema.agg_retention WHERE day_number = 7 ORDER BY cohort_date",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "D1" },
            "properties": [{ "id": "displayName", "value": "D1 Retention" }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "D7" },
            "properties": [
              { "id": "displayName", "value": "D7 Retention" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ],
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["cinema", "analytics"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "UTC",
  "title": "Cinema Analytics",
  "uid": "cinema-analytics-v1",
  "version": 2
}
